#!/usr/bin/env sh
set -e

# Pre-push: coverage gates (spec + line) + specs validators + markdown + env + conditional gates
# test:integration and test:e2e are NOT here — CRON-only (Test Lifecycle Architecture)
# If pre-push times out, run the nx affected commands below first to warm cache, then push again.
PARALLEL=$(( $(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4) - 1 ))

# 1. Coverage gates (lead the pre-push per BLOCK 1-B)
# specs:coverage: every .feature scenario implemented across unit+integration+e2e per app
npx nx affected -t specs:coverage --parallel="$PARALLEL"

# 2. Markdown lint
npm run lint:md

# 3. Env validation
npx nx run rhino-cli:env:validation

# 4. Named validators — scoped to pushes that touch the relevant trees
RANGE=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1 && echo '@{u}..HEAD' || echo "")
if [ -n "$RANGE" ]; then
  CHANGED=$(git diff --name-only "$RANGE" 2>/dev/null || echo "")

  if echo "$CHANGED" | grep -qE '^(\.claude/agents/|\.opencode/agents/)'; then
    npx nx run rhino-cli:naming:harness-validation
  fi
  if echo "$CHANGED" | grep -qE '^repo-governance/workflows/'; then
    npx nx run rhino-cli:naming:workflows-validation
  fi
  if echo "$CHANGED" | grep -qE '^(repo-governance/.*\.md|AGENTS\.md|CLAUDE\.md|\.claude/agents/|\.opencode/agents/)'; then
    npx nx run rhino-cli:cross-vendor:parity-validation
  fi
  if echo "$CHANGED" | grep -qE '^(\.amazonq/|AGENTS\.md|docs/reference/platform-bindings\.md|\.claude/|\.opencode/|\.codex/|\.github/)'; then
    npm run validate:harness-bindings
  fi
  if echo "$CHANGED" | grep -qE '(^|/)Dockerfile(\.|$)'; then
    npx nx run rhino-cli:dockerfiles:lint
  fi
  if echo "$CHANGED" | grep -qE '\.sh$|^\.husky/'; then
    npx nx run rhino-cli:shell:lint
  fi
  if echo "$CHANGED" | grep -qE '^\.github/workflows/'; then
    npx nx run rhino-cli:actions:lint
  fi
fi
