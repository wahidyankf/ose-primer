#!/usr/bin/env sh
set -e

# Pre-commit: rhino-cli checks (formatting, link validation, config sync)
# Pre-push: typecheck + lint + test:quick + spec-coverage + markdown linting (all cacheable by Nx)
# If pre-push times out, run `npx nx affected -t typecheck lint test:quick spec-coverage` first to warm the cache, then push again
PARALLEL=$(( $(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4) - 1 ))
npx nx affected -t typecheck lint test:quick spec-coverage --parallel="$PARALLEL"
npm run lint:md
npx nx run rhino-cli:env:validate

# Naming validators — scoped to pushes that touch the relevant trees.
# Upstream may be missing on first push of a branch; default to empty range in that case.
RANGE=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' >/dev/null 2>&1 && echo '@{u}..HEAD' || echo "")
if [ -n "$RANGE" ]; then
  CHANGED=$(git diff --name-only "$RANGE" 2>/dev/null || echo "")
  if echo "$CHANGED" | grep -qE '^(\.claude/agents/|\.opencode/agents/)'; then
    npx nx run rhino-cli:validate:naming-agents
  fi
  if echo "$CHANGED" | grep -qE '^repo-governance/workflows/'; then
    npx nx run rhino-cli:validate:naming-workflows
  fi
  # Cross-vendor parity gate (W5 of adopt-ose-public plan): fires when any
  # parity-relevant surface changes. Cheap (~5s); not cacheable.
  if echo "$CHANGED" | grep -qE '^(repo-governance/.*\.md|AGENTS\.md|CLAUDE\.md|\.claude/agents/|\.opencode/agents/)'; then
    npx nx run rhino-cli:validate:cross-vendor-parity
  fi
  # Deterministic harness-binding parity guard (multi-harness-compatibility plan):
  # fires when any binding surface changes. Re-derives the generated bindings from
  # AGENTS.md and asserts byte-equality + catalog coverage. No network, no agent.
  if echo "$CHANGED" | grep -qE '^(\.amazonq/|AGENTS\.md|docs/reference/platform-bindings\.md|\.claude/|\.opencode/|\.codex/|\.github/)'; then
    npm run validate:harness-bindings
  fi
  # Infra-lint gates (lint-safety-parity D6/D7/D8) — scoped to pushes that touch
  # the relevant trees. Each nx target is cached, so an unchanged tree is a no-op.
  if echo "$CHANGED" | grep -qE '(^|/)Dockerfile(\.|$)'; then
    npx nx run rhino-cli:lint:dockerfiles
  fi
  if echo "$CHANGED" | grep -qE '\.sh$|^\.husky/'; then
    npx nx run rhino-cli:lint:shell
  fi
  if echo "$CHANGED" | grep -qE '^\.github/workflows/'; then
    npx nx run rhino-cli:lint:actions
  fi
fi
