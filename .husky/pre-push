#!/usr/bin/env sh
set -e

# Pre-commit: rhino-cli checks (formatting, link validation, config sync)
# Pre-push: typecheck + lint + markdown linting (fast, cacheable)
# test:quick: deferred to CI (main CI workflow, PR quality gate) — can be slow for large changesets
PARALLEL=$(( $(nproc 2>/dev/null || sysctl -n hw.ncpu 2>/dev/null || echo 4) - 1 ))
npx nx affected -t typecheck lint --parallel="$PARALLEL"
npm run lint:md
