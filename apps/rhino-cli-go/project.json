{
  "name": "rhino-cli-go",
  "sourceRoot": "apps/rhino-cli-go",
  "projectType": "application",
  "tags": ["type:app", "platform:cli", "lang:golang", "domain:tooling"],
  "implicitDependencies": ["golang-commons"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "CGO_ENABLED=0 go build -o dist/rhino-cli",
        "cwd": "apps/rhino-cli-go"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "command": "CGO_ENABLED=0 go test -coverprofile=cover.out ./... && CGO_ENABLED=0 go run main.go test-coverage validate apps/rhino-cli-go/cover.out 90",
        "cwd": "apps/rhino-cli-go"
      },
      "inputs": ["{projectRoot}/**/*.go", "{workspaceRoot}/specs/apps/rhino/**/*.feature"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "CGO_ENABLED=0 go test ./... -count=1",
        "cwd": "apps/rhino-cli-go"
      },
      "inputs": ["{projectRoot}/**/*.go", "{workspaceRoot}/specs/apps/rhino/**/*.feature"]
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go run main.go",
        "cwd": "apps/rhino-cli-go"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "go mod tidy",
        "cwd": "apps/rhino-cli-go"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "CGO_ENABLED=0 go test -v -tags=integration -run TestIntegration -coverprofile=cover_spec.out ./cmd/...",
        "cwd": "apps/rhino-cli-go"
      },
      "cache": true,
      "inputs": ["{projectRoot}/cmd/**/*.go", "{workspaceRoot}/specs/apps/rhino/**/*.feature"],
      "outputs": ["{projectRoot}/cover_spec.out"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "CGO_ENABLED=0 go vet ./...",
        "cwd": "apps/rhino-cli-go"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "CGO_ENABLED=0 golangci-lint run --allow-parallel-runners ./...",
        "cwd": "apps/rhino-cli-go"
      }
    },
    "spec-coverage": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli-go main.go spec-coverage validate specs/apps/rhino/behavior/cli/gherkin apps/rhino-cli-go --shared-steps",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/rhino/behavior/cli/gherkin/**/*.feature", "{projectRoot}/**/*.go"]
    },
    "validate:naming-agents": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli-go main.go agents validate-naming",
      "cache": true,
      "inputs": [
        "{projectRoot}/**/*.go",
        "{workspaceRoot}/.claude/agents/**/*.md",
        "{workspaceRoot}/.opencode/agent/**/*.md"
      ],
      "outputs": []
    },
    "validate:naming-workflows": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli-go main.go workflows validate-naming",
      "cache": true,
      "inputs": ["{projectRoot}/**/*.go", "{workspaceRoot}/repo-governance/workflows/**/*.md"],
      "outputs": []
    },
    "validate:repo-governance-vendor-audit": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli-go main.go repo-governance vendor-audit repo-governance/",
      "cache": true,
      "inputs": ["{projectRoot}/**/*.go", "{workspaceRoot}/repo-governance/**/*.md"],
      "outputs": []
    },
    "validate:harness-bindings": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli-go main.go agents validate-bindings",
      "cache": false,
      "outputs": []
    },
    "validate:cross-vendor-parity": {
      "command": "bash apps/rhino-cli-go/scripts/validate-cross-vendor-parity.sh",
      "cache": false,
      "inputs": [
        "{projectRoot}/**/*.go",
        "{projectRoot}/scripts/validate-cross-vendor-parity.sh",
        "{workspaceRoot}/repo-governance/**/*.md",
        "{workspaceRoot}/AGENTS.md",
        "{workspaceRoot}/CLAUDE.md",
        "{workspaceRoot}/.claude/agents/**/*.md",
        "{workspaceRoot}/.opencode/agents/**/*.md"
      ],
      "outputs": []
    },
    "validate:mermaid": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli-go main.go docs validate-mermaid --max-depth=4 --exclude plans/done",
      "cache": true,
      "inputs": ["{projectRoot}/**/*.go", "{workspaceRoot}/**/*.md"],
      "outputs": []
    },
    "validate:links": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli-go main.go docs validate-links --exclude plans/done --exclude apps/crud-be-elixir-phoenix/deps --exclude apps/crud-be-kotlin-ktor/build --exclude libs/elixir-cabbage/deps --exclude libs/elixir-gherkin/deps --exclude libs/elixir-openapi-codegen/deps",
      "cache": true,
      "inputs": ["{projectRoot}/**/*.go", "{workspaceRoot}/**/*.md"],
      "outputs": []
    },
    "validate:heading-hierarchy": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli-go main.go docs validate-heading-hierarchy",
      "cache": true,
      "inputs": ["{projectRoot}/**/*.go", "{workspaceRoot}/**/*.md"],
      "outputs": []
    }
  }
}
