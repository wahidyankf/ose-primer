{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "crud-fe-dart-flutterweb",
  "sourceRoot": "apps/crud-fe-dart-flutterweb/lib",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx openapi-generator-cli generate -i $(pwd)/specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml -g dart -o $(pwd)/apps/crud-fe-dart-flutterweb/generated-contracts --additional-properties=pubName=crud_contracts --global-property=modelDocs=false,apiDocs=false && for i in 1 2 3 4 5; do [ -f $(pwd)/apps/crud-fe-dart-flutterweb/generated-contracts/lib/api.dart ] && break; sleep 1; done && mv $(pwd)/apps/crud-fe-dart-flutterweb/generated-contracts/lib/api.dart $(pwd)/apps/crud-fe-dart-flutterweb/generated-contracts/lib/crud_contracts.dart && cd $(pwd)/apps/crud-fe-dart-flutterweb && flutter pub get"
      },
      "dependsOn": ["crud-contracts:bundle"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated-contracts"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter run -d chrome --web-port 3301",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "flutter build web --release",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/build/web"],
      "dependsOn": ["codegen"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "dependsOn": ["codegen"],
      "options": {
        "command": "dart analyze --fatal-infos",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "dependsOn": ["codegen"],
      "options": {
        "command": "dart analyze --fatal-infos",
        "cwd": "{projectRoot}"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-fe-dart-flutterweb:typecheck",
          "nx run crud-fe-dart-flutterweb:lint",
          "nx run crud-fe-dart-flutterweb:test:unit",
          "nx run crud-fe-dart-flutterweb:test:coverage",
          "nx run crud-fe-dart-flutterweb:test:specs"
        ],
        "parallel": false
      },
      "cache": true
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["codegen"],
      "inputs": ["default", "{projectRoot}/generated-contracts/**/*"],
      "outputs": ["{projectRoot}/coverage/"],
      "options": {
        "command": "flutter test test/unit --coverage",
        "cwd": "{projectRoot}"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "cache": true,
      "dependsOn": ["codegen"],
      "inputs": [
        "default",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-web/gherkin/**/*.feature"
      ],
      "options": {
        "command": "flutter test test/unit",
        "cwd": "{projectRoot}"
      }
    },
    "specs:behavior:coverage": {
      "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs behavior-coverage validate --shared-steps --exclude-dir codegen specs/apps/crud/behavior/crud-web/gherkin apps/crud-fe-dart-flutterweb",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/behavior/crud-web/gherkin/**/*.feature", "{projectRoot}/**/*.dart"]
    },
    "specs:structure-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs structure validate"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/apps/rhino-cli/src/**/*.rs", "{workspaceRoot}/specs/apps/**/*"]
    },
    "test:specs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-fe-dart-flutterweb:specs:structure-validation",
          "nx run crud-fe-dart-flutterweb:specs:behavior:coverage"
        ],
        "parallel": false
      },
      "cache": true
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:integration: no integration tests (echo placeholder)'"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "osv-scanner --lockfile pubspec.lock",
        "cwd": "apps/crud-fe-dart-flutterweb"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "tags": ["type:app", "platform:flutter", "lang:dart", "domain:crud-fe"],
  "implicitDependencies": ["crud-contracts", "rhino-cli"]
}
