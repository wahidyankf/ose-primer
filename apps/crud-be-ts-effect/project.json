{
  "name": "crud-be-ts-effect",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/crud-be-ts-effect/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx @hey-api/openapi-ts -i specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml -o apps/crud-be-ts-effect/generated-contracts -s"
      },
      "dependsOn": ["crud-contracts:bundle"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated-contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vite build",
        "cwd": "apps/crud-be-ts-effect"
      },
      "dependsOn": ["codegen"],
      "outputs": ["{projectRoot}/dist"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsx watch src/main.ts",
        "cwd": "apps/crud-be-ts-effect"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node dist/main.js",
        "cwd": "apps/crud-be-ts-effect"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-be-ts-effect:typecheck",
          "nx run crud-be-ts-effect:lint",
          "nx run crud-be-ts-effect:test:unit",
          "nx run crud-be-ts-effect:test:coverage",
          "nx run crud-be-ts-effect:test:specs"
        ],
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "specs"]
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx vitest run --coverage",
          "npx cucumber-js '../../specs/apps/crud/behavior/crud-be/gherkin/**/*.feature' --require-module tsx/cjs --require 'tests/unit/bdd/hooks.ts' --require 'tests/unit/bdd/world.ts' --require 'tests/unit/bdd/steps/**/*.ts' --format progress --format 'json:coverage/cucumber-unit-report.json'"
        ],
        "parallel": false,
        "cwd": "apps/crud-be-ts-effect"
      },
      "dependsOn": ["codegen"],
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/tests/unit/**/*.ts",
        "{projectRoot}/vitest.config.ts",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/coverage"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx vitest run tests/unit",
          "npx cucumber-js '../../specs/apps/crud/behavior/crud-be/gherkin/**/*.feature' --require-module tsx/cjs --require 'tests/unit/bdd/hooks.ts' --require 'tests/unit/bdd/world.ts' --require 'tests/unit/bdd/steps/**/*.ts' --format progress --format 'json:coverage/cucumber-unit-report.json'"
        ],
        "parallel": false,
        "cwd": "apps/crud-be-ts-effect"
      },
      "dependsOn": ["codegen"],
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/tests/unit/**/*.ts",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --exit-code-from test-runner --build",
        "cwd": "apps/crud-be-ts-effect"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint .",
        "cwd": "apps/crud-be-ts-effect"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit",
        "cwd": "apps/crud-be-ts-effect"
      },
      "dependsOn": ["codegen"],
      "cache": true
    },
    "specs:structure-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs structure validate"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/apps/rhino-cli/src/**/*.rs", "{workspaceRoot}/specs/apps/**/*"]
    },
    "specs:behavior:coverage": {
      "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs behavior-coverage validate --shared-steps --exclude-dir test-support --exclude-dir codegen specs/apps/crud/behavior/crud-be/gherkin apps/crud-be-ts-effect",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature", "{projectRoot}/**/*.{ts,tsx}"]
    },
    "specs:domain:coverage": {
      "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs domain-coverage validate --shared-steps --exclude-dir test-support --exclude-dir codegen specs/apps/crud/behavior/crud-be/gherkin apps/crud-be-ts-effect",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature", "{projectRoot}/**/*.{ts,tsx}"]
    },
    "test:specs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-be-ts-effect:specs:structure-validation",
          "nx run crud-be-ts-effect:specs:behavior:coverage",
          "nx run crud-be-ts-effect:specs:domain:coverage"
        ],
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "specs"]
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm audit --audit-level=moderate",
        "cwd": "apps/crud-be-ts-effect"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "namedInputs": {
    "specs": ["{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature"]
  },
  "tags": ["type:app", "platform:effect", "lang:typescript", "domain:crud-be"],
  "implicitDependencies": ["crud-contracts", "rhino-cli"]
}
