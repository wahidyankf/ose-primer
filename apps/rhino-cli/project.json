{
  "name": "rhino-cli",
  "sourceRoot": "apps/rhino-cli",
  "projectType": "application",
  "tags": ["type:app", "platform:cli", "lang:rust", "domain:tooling"],
  "implicitDependencies": [],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build --release --manifest-path apps/rhino-cli/Cargo.toml && mkdir -p apps/rhino-cli/dist && cp apps/rhino-cli/target/release/rhino-cli apps/rhino-cli/dist/rhino-cli"
      },
      "outputs": ["{projectRoot}/dist"]
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fetch --manifest-path apps/rhino-cli/Cargo.toml"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "cargo fmt --manifest-path apps/rhino-cli/Cargo.toml -- --check",
          "cargo clippy --manifest-path apps/rhino-cli/Cargo.toml --all-targets -- -D warnings"
        ],
        "parallel": false
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "bash apps/rhino-cli/scripts/deny-check.sh"
      },
      "cache": false,
      "inputs": [
        "{projectRoot}/Cargo.toml",
        "{projectRoot}/Cargo.lock",
        "{projectRoot}/deny.toml",
        "{projectRoot}/scripts/deny-check.sh"
      ]
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo hack --manifest-path apps/rhino-cli/Cargo.toml check --rust-version"
      },
      "cache": true,
      "inputs": ["{projectRoot}/Cargo.toml", "{projectRoot}/src/**/*.rs"]
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --manifest-path apps/rhino-cli/Cargo.toml --"
      }
    },
    "specs:behavior:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Phase 1 — specs:behavior:coverage stub; full @covers wiring lands in Phase 1b wiring step'"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/rhino/behavior/rhino-cli/gherkin/**/*.feature", "{projectRoot}/**/*.rs"]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test --manifest-path apps/rhino-cli/Cargo.toml --tests"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/Cargo.toml",
        "{projectRoot}/src/**/*.rs",
        "{projectRoot}/tests/**/*.rs",
        "{projectRoot}/tests/golden-master/**/*",
        "{workspaceRoot}/specs/apps/rhino/**/*.feature"
      ]
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo llvm-cov --manifest-path apps/rhino-cli/Cargo.toml --lib --ignore-filename-regex '(cli\\.rs|main\\.rs|internal/git\\.rs|commands/git_pre_commit\\.rs|commands/env_|commands/doctor\\.rs|application/git/pre_commit\\.rs|infrastructure/git/|application/doctor/tools\\.rs|application/doctor/fixer\\.rs|application/doctor/checker\\.rs|application/testcoverage/diff\\.rs|application/testcoverage/merge\\.rs|application/env/)' --lcov --output-path apps/rhino-cli/lcov.info --fail-under-lines 90"
      },
      "cache": true,
      "inputs": ["{projectRoot}/Cargo.toml", "{projectRoot}/src/**/*.rs"],
      "outputs": ["{projectRoot}/lcov.info"]
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx nx run rhino-cli:typecheck",
          "npx nx run rhino-cli:lint",
          "npx nx run rhino-cli:test:unit",
          "npx nx run rhino-cli:test:coverage",
          "npx nx run rhino-cli:test:specs"
        ],
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "specs"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo test --manifest-path apps/rhino-cli/Cargo.toml --lib"
      },
      "cache": true,
      "inputs": ["{projectRoot}/Cargo.toml", "{projectRoot}/src/**/*.rs"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo check --manifest-path apps/rhino-cli/Cargo.toml --all-targets"
      }
    },
    "specs:structure-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs structure validate"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.rs", "{workspaceRoot}/specs/apps/**/*"]
    },
    "test:specs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["npx nx run rhino-cli:specs:structure-validation", "npx nx run rhino-cli:specs:behavior:coverage"],
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "specs"]
    },
    "specs:gherkin-cardinality-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs gherkin-cardinality validate"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.rs", "{workspaceRoot}/specs/**/*.feature"]
    },
    "naming:harness-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- harness naming validate"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.rs",
        "{workspaceRoot}/.claude/agents/**/*.md",
        "{workspaceRoot}/.opencode/agents/**/*.md"
      ]
    },
    "naming:workflows-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- repo-governance workflows naming validate"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.rs", "{workspaceRoot}/repo-governance/workflows/**/*.md"]
    },
    "governance:vendor-audit-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- repo-governance vendor validate repo-governance/"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.rs", "{workspaceRoot}/repo-governance/**/*.md"]
    },
    "instruction-size:validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- harness instruction-size validate"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.rs",
        "{workspaceRoot}/repo-config.yml",
        "{workspaceRoot}/AGENTS.md",
        "{workspaceRoot}/CLAUDE.md"
      ]
    },
    "env:validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- env validate"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.rs",
        "{workspaceRoot}/repo-config.yml",
        "{workspaceRoot}/apps/**/.env.example",
        "{workspaceRoot}/apps/*/src/env.ts",
        "{workspaceRoot}/apps/*/src/**/*.rs"
      ]
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'no-op: target not applicable for this project'"
      },
      "cache": true
    }
  },
  "namedInputs": {
    "specs": ["{workspaceRoot}/specs/apps/rhino/behavior/rhino-cli/gherkin/**/*.feature"]
  }
}
