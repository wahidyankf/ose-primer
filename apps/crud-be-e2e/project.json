{
  "name": "crud-be-e2e",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "sourceRoot": "apps/crud-be-e2e/tests",
  "targets": {
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm install",
        "cwd": "apps/crud-be-e2e"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest .",
        "cwd": "apps/crud-be-e2e"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx tsc --noEmit",
        "cwd": "apps/crud-be-e2e"
      },
      "inputs": ["default", "{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature"]
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-be-e2e:typecheck",
          "nx run crud-be-e2e:lint",
          "nx run crud-be-e2e:test:unit",
          "nx run crud-be-e2e:test:coverage",
          "nx run crud-be-e2e:test:specs"
        ],
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "specs"]
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:coverage: no coverage tool configured (echo placeholder)'"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test",
        "cwd": "apps/crud-be-e2e"
      }
    },
    "test:e2e:no-test-api": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --grep-invert 'Test Support API'",
        "cwd": "apps/crud-be-e2e"
      }
    },
    "test:e2e:shard": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --shard=${SHARD}",
        "cwd": "apps/crud-be-e2e"
      }
    },
    "test:e2e:ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --ui",
        "cwd": "apps/crud-be-e2e"
      }
    },
    "test:e2e:report": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright show-report",
        "cwd": "apps/crud-be-e2e"
      }
    },
    "specs:structure-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs structure validate"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/apps/rhino-cli/src/**/*.rs", "{workspaceRoot}/specs/apps/**/*"]
    },
    "specs:behavior:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs behavior-coverage validate --shared-steps --exclude-dir codegen specs/apps/crud/behavior/crud-be/gherkin apps/crud-be-e2e"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature", "{projectRoot}/**/*.ts"]
    },
    "specs:e2e:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && cargo run --release --quiet --manifest-path ../../apps/rhino-cli/Cargo.toml -- specs e2e-coverage validate --project crud-be-e2e --features \"../../specs/apps/crud/behavior/crud-be/gherkin/**/*.feature\" --features-gen .features-gen --baseline e2e-coverage-baseline.json",
        "cwd": "apps/crud-be-e2e"
      },
      "cache": true,
      "inputs": [
        "{workspaceRoot}/apps/rhino-cli/src/**/*.rs",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature",
        "{projectRoot}/tests/steps/**/*.ts",
        "{projectRoot}/playwright.config.ts",
        "{projectRoot}/e2e-coverage-baseline.json"
      ]
    },
    "test:specs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-be-e2e:specs:structure-validation",
          "nx run crud-be-e2e:specs:behavior:coverage",
          "nx run crud-be-e2e:specs:e2e:coverage"
        ],
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "specs"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:unit: no unit tests (echo placeholder)'"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:integration: no integration tests (echo placeholder)'"
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm audit --audit-level=moderate",
        "cwd": "apps/crud-be-e2e"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "namedInputs": {
    "specs": ["{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature"]
  },
  "tags": ["type:e2e", "platform:playwright", "lang:ts", "domain:crud-be"],
  "implicitDependencies": [
    "crud-be-java-springboot",
    "crud-be-elixir-phoenix",
    "crud-be-fsharp-giraffe",
    "crud-be-golang-gin",
    "crud-be-python-fastapi",
    "crud-be-rust-axum",
    "crud-be-kotlin-ktor",
    "crud-be-java-vertx",
    "crud-be-ts-effect",
    "crud-be-csharp-aspnetcore",
    "crud-be-clojure-pedestal",
    "crud-contracts"
  ]
}
