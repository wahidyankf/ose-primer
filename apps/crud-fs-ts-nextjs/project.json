{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "crud-fs-ts-nextjs",
  "sourceRoot": "apps/crud-fs-ts-nextjs/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx @hey-api/openapi-ts -i specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml -o apps/crud-fs-ts-nextjs/src/generated-contracts -s"
      },
      "dependsOn": ["crud-contracts:bundle"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/src/generated-contracts"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next dev --port 3401",
        "cwd": "{projectRoot}"
      }
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next build",
        "cwd": "{projectRoot}"
      },
      "outputs": ["{projectRoot}/.next"],
      "dependsOn": ["codegen"]
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "next start --port 3401",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["codegen"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest --jsx-a11y-plugin .",
        "cwd": "{projectRoot}"
      },
      "inputs": ["{projectRoot}/src/**/*", "{projectRoot}/oxlint.json", "{projectRoot}/tsconfig.json"]
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-fs-ts-nextjs:typecheck",
          "nx run crud-fs-ts-nextjs:lint",
          "nx run crud-fs-ts-nextjs:test:unit",
          "nx run crud-fs-ts-nextjs:test:coverage",
          "nx run crud-fs-ts-nextjs:test:specs"
        ],
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "specs"]
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "dependsOn": ["codegen"],
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/src/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-web/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/coverage"],
      "options": {
        "command": "npx vitest run --coverage",
        "cwd": "{projectRoot}"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "default",
        "{projectRoot}/src/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-web/gherkin/**/*.feature"
      ],
      "options": {
        "command": "npx vitest run",
        "cwd": "{projectRoot}"
      },
      "dependsOn": ["codegen"]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --exit-code-from test-runner --build",
        "cwd": "apps/crud-fs-ts-nextjs"
      },
      "cache": false
    },
    "specs:structure-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs structure validate"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/apps/rhino-cli/src/**/*.rs", "{workspaceRoot}/specs/apps/**/*"]
    },
    "specs:behavior:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs behavior-coverage validate --shared-steps --exclude-dir codegen specs/apps/crud/behavior/crud-be/gherkin specs/apps/crud/behavior/crud-web/gherkin apps/crud-fs-ts-nextjs"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/**/*.feature", "{projectRoot}/**/*.{ts,tsx}"]
    },
    "test:specs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-fs-ts-nextjs:specs:structure-validation",
          "nx run crud-fs-ts-nextjs:specs:behavior:coverage"
        ],
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "specs"]
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm audit --audit-level=moderate",
        "cwd": "apps/crud-fs-ts-nextjs"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "namedInputs": {
    "specs": ["{workspaceRoot}/specs/apps/crud/**/*.feature"]
  },
  "tags": ["type:app", "platform:nextjs", "lang:ts", "domain:crud-fs"],
  "implicitDependencies": ["crud-contracts", "rhino-cli"]
}
