{
  "name": "rhino-cli-rust",
  "sourceRoot": "apps/rhino-cli-rust/src",
  "projectType": "application",
  "tags": ["type:app", "platform:cli", "lang:rust", "domain:tooling"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo build --release --manifest-path apps/rhino-cli-rust/Cargo.toml && mkdir -p apps/rhino-cli-rust/dist && cp apps/rhino-cli-rust/target/release/rhino-cli apps/rhino-cli-rust/dist/rhino-cli"
      },
      "outputs": ["{projectRoot}/dist", "{projectRoot}/target"]
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fetch --manifest-path apps/rhino-cli-rust/Cargo.toml"
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --manifest-path apps/rhino-cli-rust/Cargo.toml --"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo check --manifest-path apps/rhino-cli-rust/Cargo.toml --all-targets"
      }
    },
    "fmt": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo fmt --manifest-path apps/rhino-cli-rust/Cargo.toml"
      }
    },
    "fmt:check": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.rs", "{projectRoot}/.rustfmt.toml", "{workspaceRoot}/.rustfmt.toml"],
      "options": {
        "command": "cargo fmt --manifest-path apps/rhino-cli-rust/Cargo.toml -- --check"
      }
    },
    "deny:check": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{projectRoot}/Cargo.toml", "{projectRoot}/Cargo.lock", "{projectRoot}/deny.toml"],
      "options": {
        "command": "cargo deny --manifest-path apps/rhino-cli-rust/Cargo.toml check"
      }
    },
    "check:msrv": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{projectRoot}/Cargo.toml", "{projectRoot}/src/**/*.rs"],
      "options": {
        "command": "cargo hack --manifest-path apps/rhino-cli-rust/Cargo.toml check --rust-version"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "cargo fmt --manifest-path apps/rhino-cli-rust/Cargo.toml -- --check",
          "cargo clippy --manifest-path apps/rhino-cli-rust/Cargo.toml --all-targets -- -D warnings"
        ],
        "parallel": false
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": ["{projectRoot}/Cargo.toml", "{projectRoot}/src/**/*.rs"],
      "options": {
        "command": "cargo test --manifest-path apps/rhino-cli-rust/Cargo.toml --lib"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo llvm-cov --manifest-path apps/rhino-cli-rust/Cargo.toml --lib --ignore-filename-regex '(cli\\.rs|main\\.rs|commands/testcoverage\\.rs|commands/speccoverage\\.rs|commands/docs\\.rs|commands/agents\\.rs|commands/git\\.rs|commands/contracts\\.rs|commands/java\\.rs|commands/env\\.rs|commands/doctor\\.rs|internal/git/root\\.rs|internal/git/runner\\.rs|internal/testcoverage/diff\\.rs|internal/testcoverage/merge\\.rs)' --lcov --output-path apps/rhino-cli-rust/lcov.info --fail-under-lines 90"
      },
      "inputs": ["{projectRoot}/src/**/*.rs", "{projectRoot}/Cargo.toml"],
      "outputs": ["{projectRoot}/lcov.info"],
      "comment": "Library coverage gate at 90% lines. Ignored files are exercised only via integration tests / git- and external-tool-dependent paths: cli.rs + main.rs (entrypoint/dispatch), commands/*.rs (thin clap adapters covered by cucumber tests — testcoverage, speccoverage, docs, agents, git, contracts, java, env, doctor), internal/git/root.rs (filesystem walk-up + os.Getwd-parity logical-path resolution), internal/git/runner.rs (pre-commit orchestrator whose steps shell out to docker/nx/npx/npm/git — only the error path is byte-checkable; its branch logic is covered by injected-Deps unit tests), and testcoverage/{diff,merge}.rs (git-diff and on-disk-merge paths). The env/doctor engines (internal/envbackup/*, internal/doctor/*) carry the logic and are unit-tested directly. Actual measured lines coverage is ~92%."
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "cache": true,
      "inputs": [
        "{projectRoot}/Cargo.toml",
        "{projectRoot}/src/**/*.rs",
        "{projectRoot}/tests/**/*.rs",
        "{workspaceRoot}/specs/apps/rhino/**/*.feature"
      ],
      "options": {
        "command": "cargo test --manifest-path apps/rhino-cli-rust/Cargo.toml --tests"
      }
    },
    "spec-coverage": {
      "command": "cargo run --release -q --manifest-path apps/rhino-cli-rust/Cargo.toml -- spec-coverage validate specs/apps/rhino/behavior/cli/gherkin apps/rhino-cli-go --shared-steps",
      "cache": true,
      "inputs": [
        "{workspaceRoot}/specs/apps/rhino/behavior/cli/gherkin/**/*.feature",
        "{projectRoot}/src/**/*.rs",
        "{workspaceRoot}/apps/rhino-cli-go/**/*.go"
      ],
      "comment": "Mirrors rhino-cli-go:spec-coverage exactly (same gherkin dir + scanned impl dir + --shared-steps), swapping only the binary to the Rust port. The shared-steps validator confirms every gherkin step has a matching step definition in the canonical Go test suite; the Rust binary produces byte-identical results (verified via shadow-diff `sc shared`). Scanning apps/rhino-cli-go (not apps/rhino-cli-rust) is intentional: the Go test suite is the canonical fully-covered implementation, and the parity-locked literal-step extractor (shared by both binaries) does not recognise the `regex = r\"...\"` cucumber-rs attribute form the Rust tests use, so scanning the Rust tree would report false-positive gaps identical under either binary."
    },
    "validate:naming-agents": {
      "command": "cargo run --release -q --manifest-path apps/rhino-cli-rust/Cargo.toml -- agents validate-naming",
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.rs",
        "{workspaceRoot}/.claude/agents/**/*.md",
        "{workspaceRoot}/.opencode/agent/**/*.md"
      ],
      "outputs": []
    },
    "validate:naming-workflows": {
      "command": "cargo run --release -q --manifest-path apps/rhino-cli-rust/Cargo.toml -- workflows validate-naming",
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.rs", "{workspaceRoot}/repo-governance/workflows/**/*.md"],
      "outputs": []
    },
    "validate:repo-governance-vendor-audit": {
      "command": "cargo run --release -q --manifest-path apps/rhino-cli-rust/Cargo.toml -- repo-governance vendor-audit repo-governance/",
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.rs", "{workspaceRoot}/repo-governance/**/*.md"],
      "outputs": []
    },
    "validate:harness-bindings": {
      "command": "cargo run --release -q --manifest-path apps/rhino-cli-rust/Cargo.toml -- agents validate-bindings",
      "cache": false,
      "outputs": []
    },
    "validate:cross-vendor-parity": {
      "command": "bash apps/rhino-cli-rust/scripts/validate-cross-vendor-parity.sh",
      "cache": false,
      "inputs": [
        "{projectRoot}/**/*.rs",
        "{projectRoot}/scripts/validate-cross-vendor-parity.sh",
        "{workspaceRoot}/repo-governance/**/*.md",
        "{workspaceRoot}/AGENTS.md",
        "{workspaceRoot}/CLAUDE.md",
        "{workspaceRoot}/.claude/agents/**/*.md",
        "{workspaceRoot}/.opencode/agents/**/*.md"
      ],
      "outputs": []
    },
    "validate:mermaid": {
      "command": "cargo run --release -q --manifest-path apps/rhino-cli-rust/Cargo.toml -- docs validate-mermaid",
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.rs",
        "{workspaceRoot}/docs/**/*.md",
        "{workspaceRoot}/repo-governance/**/*.md",
        "{workspaceRoot}/.claude/**/*.md",
        "{workspaceRoot}/plans/**/*.md",
        "{workspaceRoot}/*.md"
      ],
      "outputs": []
    }
  }
}
