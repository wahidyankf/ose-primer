{
  "name": "crud-be-java-vertx",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/crud-be-java-vertx/src",
  "projectType": "application",
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx openapi-generator-cli generate -i $(pwd)/specs/apps/crud/contracts/generated/openapi-bundled.yaml -g java -o $(pwd)/apps/crud-be-java-vertx/generated-contracts --model-package com.demobejavx.contracts --additional-properties=library=resttemplate,dateLibrary=java8,openApiNullable=false,useBeanValidation=false,serializationLibrary=jackson --global-property=models,modelDocs=false,apiDocs=false && (WS_ROOT=$(pwd) && cd $(pwd)/apps/rhino-cli && CGO_ENABLED=0 go run main.go contracts java-clean-imports $WS_ROOT/apps/crud-be-java-vertx/generated-contracts)"
      },
      "dependsOn": ["crud-contracts:bundle"],
      "cache": true,
      "inputs": [
        "{workspaceRoot}/specs/apps/crud/contracts/generated/openapi-bundled.yaml",
        "{workspaceRoot}/apps/rhino-cli/cmd/**/*.go",
        "{workspaceRoot}/apps/rhino-cli/internal/**/*.go"
      ],
      "outputs": ["{projectRoot}/generated-contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn clean package -DskipTests",
        "cwd": "apps/crud-be-java-vertx"
      },
      "outputs": ["{projectRoot}/target"],
      "dependsOn": ["codegen"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn compile exec:java -Dexec.mainClass=com.demobejavx.Main",
        "cwd": "apps/crud-be-java-vertx"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "sh -c 'java -jar target/crud-be-java-vertx-*.jar'",
        "cwd": "apps/crud-be-java-vertx"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "mvn test",
          "(cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate apps/crud-be-java-vertx/target/site/jacoco/jacoco.xml 90)"
        ],
        "parallel": false,
        "cwd": "apps/crud-be-java-vertx"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/pom.xml",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/crud/be/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/target/site/jacoco/jacoco.xml"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mvn test",
        "cwd": "apps/crud-be-java-vertx"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**",
        "{projectRoot}/pom.xml",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/crud/be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --build",
        "cwd": "apps/crud-be-java-vertx"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["mvn checkstyle:check", "mvn pmd:check"],
        "parallel": false,
        "cwd": "apps/crud-be-java-vertx"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run rhino-cli:build --skip-nx-cache && ./apps/rhino-cli/dist/rhino-cli java validate-annotations apps/crud-be-java-vertx/src/main/java",
          "cd apps/crud-be-java-vertx && mvn compile -Pnullcheck"
        ],
        "parallel": false
      },
      "dependsOn": ["codegen"],
      "cache": true
    },
    "spec-coverage": {
      "command": "CGO_ENABLED=0 go run -C apps/rhino-cli main.go spec-coverage validate --shared-steps --exclude-dir test-support specs/apps/crud/be/gherkin apps/crud-be-java-vertx",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/be/gherkin/**/*.feature", "{projectRoot}/**/*.java"]
    }
  },
  "tags": ["type:app", "platform:vertx", "lang:java", "domain:demo-be"],
  "implicitDependencies": ["crud-contracts", "rhino-cli"]
}
