{
  "name": "crud-be-clojure-pedestal",
  "sourceRoot": "apps/crud-be-clojure-pedestal",
  "projectType": "application",
  "tags": ["type:app", "platform:pedestal", "lang:clojure", "domain:crud-be"],
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} cd libs/clojure-openapi-codegen && clojure -M -e '(require (quote openapi-codegen.core)) (openapi-codegen.core/generate \"../../specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml\" \"../../apps/crud-be-clojure-pedestal/generated_contracts\")'"
      },
      "dependsOn": ["crud-contracts:bundle", "clojure-openapi-codegen:build"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated_contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -T:build uber",
        "cwd": "apps/crud-be-clojure-pedestal"
      },
      "dependsOn": ["codegen"],
      "outputs": ["{projectRoot}/target"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -M -m crud-be-cjpd.main",
        "cwd": "apps/crud-be-clojure-pedestal"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "java -jar target/crud-be-clojure-pedestal-standalone.jar",
        "cwd": "apps/crud-be-clojure-pedestal"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/crud-be-clojure-pedestal",
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -M:coverage -m kaocha.runner unit bdd --plugin cloverage --lcov --cov-output coverage --cov-ns-exclude-regex 'crud-be-cjpd\\.(main|routes|server|contracts|interceptors\\..*|db\\.jdbc.*|db\\.(user|expense|attachment|token)-repo|handlers\\..*)'"
      },
      "dependsOn": ["codegen"],
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/test/**/*",
        "{projectRoot}/tests.edn",
        "{projectRoot}/generated_contracts/**/*",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/coverage"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -M:test -m kaocha.runner unit bdd",
        "cwd": "apps/crud-be-clojure-pedestal"
      },
      "dependsOn": ["codegen"],
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*",
        "{projectRoot}/test/**/*",
        "{projectRoot}/tests.edn",
        "{projectRoot}/generated_contracts/**/*",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --build",
        "cwd": "apps/crud-be-clojure-pedestal"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "clj-kondo --lint src test",
        "cwd": "apps/crud-be-clojure-pedestal"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "clj-kondo --lint src",
        "cwd": "apps/crud-be-clojure-pedestal"
      },
      "dependsOn": ["codegen"],
      "cache": true
    },
    "specs:behavior:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'Phase 0 \u2014 specs:coverage stubbed; orphan step impl cleanup (dead steps + Clojure extractor gaps) lands in Phase 1'"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature", "{projectRoot}/**/*.clj"]
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -M:nvd check",
        "cwd": "apps/crud-be-clojure-pedestal"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "implicitDependencies": ["clojure-openapi-codegen", "crud-contracts", "rhino-cli"]
}
