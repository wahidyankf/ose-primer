{
  "name": "crud-be-elixir-phoenix",
  "sourceRoot": "apps/crud-be-elixir-phoenix/lib",
  "projectType": "application",
  "implicitDependencies": ["crud-contracts", "elixir-gherkin", "elixir-cabbage", "elixir-openapi-codegen", "rhino-cli"],
  "targets": {
    "codegen": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cd libs/elixir-openapi-codegen && mix run -e 'OpenApiCodegen.generate(\"../../specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml\", \"../../apps/crud-be-elixir-phoenix/generated-contracts\")'"
      },
      "dependsOn": ["crud-contracts:bundle", "elixir-openapi-codegen:build"],
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml"],
      "outputs": ["{projectRoot}/generated-contracts"]
    },
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "MIX_ENV=prod mix do deps.get --only prod, compile --warnings-as-errors",
        "cwd": "apps/crud-be-elixir-phoenix"
      },
      "dependsOn": ["codegen"]
    },
    "dev": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix phx.server",
        "cwd": "apps/crud-be-elixir-phoenix"
      }
    },
    "start": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix phx.server",
        "cwd": "apps/crud-be-elixir-phoenix"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/crud-be-elixir-phoenix",
        "command": "MIX_ENV=test mix coveralls.lcov --only unit"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/lib/**/*.ex",
        "{projectRoot}/test/**/*.exs",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/cover/lcov.info"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "MIX_ENV=test mix test --only unit",
        "cwd": "apps/crud-be-elixir-phoenix"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/lib/**/*.ex",
        "{projectRoot}/test/**/*.exs",
        "{projectRoot}/generated-contracts/**/*",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature"
      ]
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "docker compose -f docker-compose.integration.yml down -v && docker compose -f docker-compose.integration.yml up --abort-on-container-exit --build",
        "cwd": "apps/crud-be-elixir-phoenix"
      },
      "cache": false
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix credo --strict",
        "cwd": "apps/crud-be-elixir-phoenix"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix compile --warnings-as-errors",
        "cwd": "apps/crud-be-elixir-phoenix"
      },
      "dependsOn": ["codegen"],
      "cache": true
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix deps.get",
        "cwd": "apps/crud-be-elixir-phoenix"
      }
    },
    "specs:behavior:coverage": {
      "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs validate coverage --shared-steps --exclude-dir test-support --exclude-dir codegen specs/apps/crud/behavior/crud-be/gherkin apps/crud-be-elixir-phoenix",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/behavior/crud-be/gherkin/**/*.feature", "{projectRoot}/**/*.{ex,exs}"]
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix hex.audit && mix deps.audit",
        "cwd": "apps/crud-be-elixir-phoenix"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "tags": ["type:app", "platform:phoenix", "lang:elixir", "domain:crud-be"]
}
