{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "crud-fe-e2e",
  "sourceRoot": "apps/crud-fe-e2e/tests",
  "projectType": "application",
  "targets": {
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright install --with-deps chromium",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      },
      "inputs": ["default", "{workspaceRoot}/specs/apps/crud/behavior/crud-web/gherkin/**/*.feature"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest .",
        "cwd": "{projectRoot}"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-fe-e2e:typecheck",
          "nx run crud-fe-e2e:lint",
          "nx run crud-fe-e2e:test:unit",
          "nx run crud-fe-e2e:test:coverage",
          "nx run crud-fe-e2e:test:specs"
        ],
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "specs"]
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:coverage: no coverage tool configured (echo placeholder)'"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "if grep -rn -E --include='*.ts' --exclude-dir=node_modules --exclude-dir=.features-gen --exclude-dir=test-results --exclude-dir=playwright-report '\\$?test\\.skip\\([^,)]*\\)' .; then echo 'ERROR: unconditional test.skip() found in test files above - use test.skip(condition, reason) for legitimate environment guards, or remove'; exit 1; fi && npx bddgen && npx playwright test",
        "cwd": "{projectRoot}"
      }
    },
    "test:e2e:shard": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --shard=${SHARD}",
        "cwd": "{projectRoot}"
      }
    },
    "test:e2e:ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --ui",
        "cwd": "{projectRoot}"
      }
    },
    "test:e2e:report": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright show-report",
        "cwd": "{projectRoot}"
      }
    },
    "specs:structure-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs structure validate"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/apps/rhino-cli/src/**/*.rs", "{workspaceRoot}/specs/apps/**/*"]
    },
    "specs:behavior:coverage": {
      "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs behavior-coverage validate --shared-steps --exclude-dir codegen specs/apps/crud/behavior/crud-web/gherkin apps/crud-fe-e2e",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/behavior/crud-web/gherkin/**/*.feature", "{projectRoot}/**/*.ts"]
    },
    "specs:e2e:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && cargo run --release --quiet --manifest-path ../../apps/rhino-cli/Cargo.toml -- specs e2e-coverage validate --project crud-fe-e2e --features \"../../specs/apps/crud/behavior/crud-web/gherkin/**/*.feature\" --features-gen .features-gen --baseline e2e-coverage-baseline.json",
        "cwd": "apps/crud-fe-e2e"
      },
      "cache": true,
      "inputs": [
        "{workspaceRoot}/apps/rhino-cli/src/**/*.rs",
        "{workspaceRoot}/specs/apps/crud/behavior/crud-web/gherkin/**/*.feature",
        "{projectRoot}/tests/steps/**/*.steps.ts",
        "{projectRoot}/playwright.config.ts",
        "{projectRoot}/e2e-coverage-baseline.json"
      ]
    },
    "test:specs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-fe-e2e:specs:structure-validation",
          "nx run crud-fe-e2e:specs:behavior:coverage",
          "nx run crud-fe-e2e:specs:e2e:coverage"
        ],
        "parallel": false
      },
      "cache": true,
      "inputs": ["default", "specs"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:unit: no unit tests (echo placeholder)'"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:integration: no integration tests (echo placeholder)'"
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm audit --audit-level=moderate",
        "cwd": "apps/crud-fe-e2e"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "namedInputs": {
    "specs": ["{workspaceRoot}/specs/apps/crud/behavior/crud-web/gherkin/**/*.feature"]
  },
  "tags": ["type:e2e", "platform:playwright", "lang:ts", "domain:crud-fe"],
  "implicitDependencies": [
    "crud-fe-ts-nextjs",
    "crud-fe-dart-flutterweb",
    "crud-fe-ts-tanstack-start",
    "crud-contracts"
  ]
}
