{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "crud-fe-e2e",
  "sourceRoot": "apps/crud-fe-e2e/tests",
  "projectType": "application",
  "targets": {
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright install --with-deps chromium",
        "cwd": "{projectRoot}"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit",
        "cwd": "{projectRoot}"
      },
      "inputs": ["default", "{workspaceRoot}/specs/apps/crud/behavior/crud-web/gherkin/**/*.feature"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest .",
        "cwd": "{projectRoot}"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsc --noEmit", "npx oxlint@latest ."],
        "parallel": true,
        "cwd": "{projectRoot}"
      },
      "inputs": ["default", "{workspaceRoot}/specs/apps/crud/behavior/crud-web/gherkin/**/*.feature"]
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test",
        "cwd": "{projectRoot}"
      }
    },
    "test:e2e:shard": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --shard=${SHARD}",
        "cwd": "{projectRoot}"
      }
    },
    "test:e2e:ui": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx bddgen && npx playwright test --ui",
        "cwd": "{projectRoot}"
      }
    },
    "test:e2e:report": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright show-report",
        "cwd": "{projectRoot}"
      }
    },
    "specs:behavior:coverage": {
      "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs behavior-coverage validate --shared-steps --exclude-dir codegen specs/apps/crud/behavior/crud-web/gherkin apps/crud-fe-e2e",
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/apps/crud/behavior/crud-web/gherkin/**/*.feature", "{projectRoot}/**/*.ts"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:unit: no unit tests (echo placeholder)'"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:integration: no integration tests (echo placeholder)'"
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm audit --audit-level=moderate",
        "cwd": "apps/crud-fe-e2e"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "tags": ["type:e2e", "platform:playwright", "lang:ts", "domain:crud-fe"],
  "implicitDependencies": [
    "crud-fe-ts-nextjs",
    "crud-fe-dart-flutterweb",
    "crud-fe-ts-tanstack-start",
    "crud-contracts"
  ]
}
