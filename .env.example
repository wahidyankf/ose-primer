# Environment variables for ose-primer
#
# Copy to `.env` and fill in real values. Files matching `.env*` are
# git-ignored (except `.env.example` itself). Never commit secrets.

# OpenCode Go API key — required for OpenCode sessions to authenticate
# against the opencode-go provider configured in `.opencode/opencode.json`.
# Without this set, OpenCode sessions fail fast with
# `ProviderModelNotFoundError: opencode-go/...`.
OPENCODE_GO_API_KEY=
