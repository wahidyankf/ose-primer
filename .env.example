# Environment variables for ose-primer
#
# Copy to `.env` and fill in real values. Files matching `.env*` are
# git-ignored (except `.env.example` itself). Never commit secrets.

# Required (for OpenCode sessions). String. API key for the opencode-go provider
# configured in `.opencode/opencode.json`. Without this set, OpenCode sessions
# fail fast with `ProviderModelNotFoundError: opencode-go/...`.
# Format: opaque string provided by the opencode-go service.
OPENCODE_GO_API_KEY=
