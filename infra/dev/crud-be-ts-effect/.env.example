# Demo Backend (TSEX — TypeScript/Effect) Environment Variables
# Copy this file to .env and configure as needed

# Optional. String. Docker Compose credential for the local PostgreSQL container.
POSTGRES_USER=crud_be_ts_effect
# Optional. String. Docker Compose credential for the local PostgreSQL container.
POSTGRES_PASSWORD=crud_be_ts_effect

# Required. String, min 32 chars. HS256 JWT signing key. Generate: openssl rand -hex 32
CRUD_BE_TS_EFFECT_JWT_SECRET=change-me-in-dev-only-not-for-production

# Optional. String. PostgreSQL URL for E2E tests (used by crud-be-e2e).
# Format: postgresql://<user>:<pass>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://crud_be_ts_effect:crud_be_ts_effect@localhost:5432/crud_be_ts_effect
