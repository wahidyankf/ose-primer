# Demo Backend (EXPH — Elixir/Phoenix) Environment Variables
# Copy this file to .env and configure as needed

# PostgreSQL credentials for local dev
POSTGRES_USER=crud_be_exph
POSTGRES_PASSWORD=crud_be_exph

# JWT signing secret (min 32 chars for HS256 security)
APP_JWT_SECRET=change-me-in-production-use-a-real-random-secret

# Database URL for E2E tests (used by crud-be-e2e)
DATABASE_URL=postgresql://crud_be_exph:crud_be_exph@localhost:5432/crud_be_exph
