# Demo Backend (EXPH — Elixir/Phoenix) Environment Variables
# Copy and rename this file before use.

# Optional. String. Docker Compose credential for the local PostgreSQL container.
POSTGRES_USER=crud_be_exph
# Optional. String. Docker Compose credential for the local PostgreSQL container.
POSTGRES_PASSWORD=crud_be_exph

# Required. String, min 64 hex chars. Phoenix session signing key. Generate: mix phx.gen.secret
SECRET_KEY_BASE=dev-only-not-for-production-change-me-generate-with-mix-phx-gen-secret
# Optional. String. Phoenix URL host (default example.com in dev). Required in prod.
PHX_HOST=localhost
# Optional. String. DNS cluster query for distributed nodes. Leave empty for single-node dev.
DNS_CLUSTER_QUERY=

# Required. String, min 32 chars. HS256 JWT signing key. Generate: openssl rand -hex 32
CRUD_BE_ELIXIR_PHOENIX_JWT_SECRET=change-me-in-production-use-a-real-random-secret

# Optional. String. PostgreSQL URL for E2E tests (used by crud-be-e2e).
# Format: postgresql://<user>:<pass>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://crud_be_exph:crud_be_exph@localhost:5432/crud_be_exph
