# CI Dockerfile — pre-compiles everything so container startup is instant.
# Build context: repo root (../../..)
FROM elixir:1.19-otp-27-alpine

# build-base required for bcrypt_elixir NIF compilation
RUN apk add --no-cache build-base curl git && \
    mix local.hex --force && \
    mix local.rebar --force

WORKDIR /workspace

# Copy app source, config, and generated contracts
COPY apps/crud-be-elixir-phoenix/mix.exs apps/crud-be-elixir-phoenix/mix.lock ./
COPY apps/crud-be-elixir-phoenix/config/ config/
COPY apps/crud-be-elixir-phoenix/lib/ lib/
COPY apps/crud-be-elixir-phoenix/priv/ priv/
COPY apps/crud-be-elixir-phoenix/generated-contracts/ generated-contracts/

# Install and compile deps + app in dev mode.
# Set ENABLE_TEST_API at build time so the router compiles test routes.
# This prevents recompilation at container startup.
ENV MIX_ENV=dev
ENV ENABLE_TEST_API=true
RUN mix deps.get && mix deps.compile && mix compile

EXPOSE 8201
CMD ["sh", "-c", "mix ecto.migrate && mix phx.server"]
