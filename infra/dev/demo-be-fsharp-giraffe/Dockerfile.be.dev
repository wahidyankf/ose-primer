# Development Docker Image for Demo Backend (FSGI — F#/Giraffe)
# Uses .NET 10 SDK for building and running the application.

FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine

# Install curl for healthcheck
RUN apk add --no-cache curl

WORKDIR /workspace

CMD ["dotnet", "run", "--project", "src/DemoBeFsgi/DemoBeFsgi.fsproj"]
