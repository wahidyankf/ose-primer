# Demo Backend (CSAS — C#/ASP.NET Core) Environment Variables
# Copy this file to .env and configure as needed

# Optional. String. Docker Compose credential for the local PostgreSQL container.
POSTGRES_USER=crud_be_csharp_aspnetcore
# Optional. String. Docker Compose credential for the local PostgreSQL container.
POSTGRES_PASSWORD=crud_be_csharp_aspnetcore

# Required. String, min 32 chars. HS256 JWT signing key. Generate: openssl rand -hex 32
CRUD_BE_CSHARP_ASPNETCORE_JWT_SECRET=change-me-in-dev-only-not-for-production

# Optional. String. ADO.NET connection string for E2E tests (used by crud-be-e2e).
# Format: Host=<host>;Port=<port>;Database=<dbname>;Username=<user>;Password=<pass>
DATABASE_URL=Host=localhost;Port=5432;Database=crud_be_csharp_aspnetcore;Username=crud_be_csharp_aspnetcore;Password=crud_be_csharp_aspnetcore
