# Development Docker Image for Demo Backend (CSAS — C#/ASP.NET Core)
# Uses .NET 10 SDK for building and running the application.

FROM mcr.microsoft.com/dotnet/sdk:10.0-alpine

# Install curl for healthcheck
RUN apk add --no-cache curl

# Install dotnet-ef for database migrations
RUN dotnet tool install -g dotnet-ef

ENV PATH="$PATH:/root/.dotnet/tools"

WORKDIR /workspace

CMD ["dotnet", "run", "--project", "src/DemoBeCsas/DemoBeCsas.csproj"]
