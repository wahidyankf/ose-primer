# Demo Backend (JAVX — Java/Vert.x) Environment Variables
# Copy this file to .env and configure as needed

# PostgreSQL credentials for local dev
POSTGRES_USER=demo_be_java_vertx
POSTGRES_PASSWORD=demo_be_java_vertx

# JWT signing secret (min 32 chars for HS256 security)
APP_JWT_SECRET=change-me-in-dev-only-not-for-production

# Database URL for E2E tests (used by demo-be-e2e)
DATABASE_URL=postgresql://demo_be_java_vertx:demo_be_java_vertx@localhost:5432/demo_be_java_vertx
