# Demo Fullstack (Next.js) Environment Variables
# Copy this file to .env and configure as needed

# PostgreSQL credentials (hardcoded in docker-compose, provided here for reference)
# POSTGRES_USER=crud_fs_ts_nextjs
# POSTGRES_PASSWORD=crud_fs_ts_nextjs

# JWT signing secret (min 32 chars for HS256 security)
APP_JWT_SECRET=dev-jwt-secret-at-least-32-chars-long!!
