# Demo Fullstack (Next.js) Environment Variables
# Copy this file to .env and configure as needed

# Optional. String. Docker Compose credentials (hardcoded in docker-compose, provided for reference).
# POSTGRES_USER=crud_fs_ts_nextjs
# POSTGRES_PASSWORD=crud_fs_ts_nextjs

# Required. String, min 32 chars. HS256 JWT signing key for this fullstack app.
# Generate: openssl rand -hex 32
CRUD_FS_TS_NEXTJS_JWT_SECRET=dev-jwt-secret-at-least-32-chars-long!!
