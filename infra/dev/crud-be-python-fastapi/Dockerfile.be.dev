# Development Docker Image for Demo Backend (PYFA — Python/FastAPI)
# Uses Python 3.13 Slim with uv for dependency management.

FROM python:3.13-slim

# Install curl for healthcheck and uv for dependency management
RUN apt-get update && apt-get install -y --no-install-recommends curl && \
    rm -rf /var/lib/apt/lists/* && \
    pip install uv

WORKDIR /workspace

CMD ["sh", "-c", "uv sync && uv run uvicorn demo_be_python_fastapi.main:app --host 0.0.0.0 --port 8201"]
