# Demo Backend (PYFA — Python/FastAPI) Environment Variables
# Copy this file to .env and configure as needed

# PostgreSQL credentials for local dev
POSTGRES_USER=demo_be_python_fastapi
POSTGRES_PASSWORD=demo_be_python_fastapi

# JWT signing secret (min 32 chars for HS256 security)
APP_JWT_SECRET=change-me-in-dev-only-not-for-production

# Database URL for E2E tests (used by demo-be-e2e)
DATABASE_URL=postgresql://demo_be_python_fastapi:demo_be_python_fastapi@localhost:5432/demo_be_python_fastapi
