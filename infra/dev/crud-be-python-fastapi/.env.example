# Demo Backend (PYFA — Python/FastAPI) Environment Variables
# Copy this file to .env and configure as needed

# PostgreSQL credentials for local dev
POSTGRES_USER=crud_be_python_fastapi
POSTGRES_PASSWORD=crud_be_python_fastapi

# JWT signing secret (min 32 chars for HS256 security)
APP_JWT_SECRET=change-me-in-dev-only-not-for-production

# Database URL for E2E tests (used by crud-be-e2e)
DATABASE_URL=postgresql://crud_be_python_fastapi:crud_be_python_fastapi@localhost:5432/crud_be_python_fastapi
