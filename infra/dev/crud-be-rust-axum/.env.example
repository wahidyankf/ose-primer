# Demo Backend (RSAX — Rust/Axum) Environment Variables
# Copy this file to .env and configure as needed

# PostgreSQL credentials for local dev
POSTGRES_USER=crud_be_rust_axum
POSTGRES_PASSWORD=crud_be_rust_axum

# JWT signing secret (min 32 chars for HS256 security)
APP_JWT_SECRET=dev-jwt-secret-that-is-32-chars-long!

# Database URL for E2E tests (used by crud-be-e2e)
DATABASE_URL=postgresql://crud_be_rust_axum:crud_be_rust_axum@localhost:5432/crud_be_rust_axum
