# Development Docker Image for Demo Backend (CJPD — Clojure/Pedestal)
# Uses Eclipse Temurin JDK 21 with Clojure CLI tools.

FROM eclipse-temurin:21-jdk-alpine

# Install Clojure CLI and wget (for healthcheck)
RUN apk add --no-cache bash curl wget rlwrap \
    && curl -L -O https://github.com/clojure/brew-install/releases/latest/download/linux-install.sh \
    && chmod +x linux-install.sh \
    && ./linux-install.sh \
    && rm linux-install.sh

# Pre-download dependencies at build time so container startup is fast
COPY apps/demo-be-clojure-pedestal/deps.edn /tmp/deps/deps.edn
RUN cd /tmp/deps && clojure -P && rm -rf /tmp/deps

WORKDIR /workspace

CMD ["clojure", "-M", "-m", "demo-be-cjpd.main"]
