# Demo Backend (JASB — Java/Spring Boot) Environment Variables
# Copy this file to .env and configure as needed

# Optional. String. Active Spring profile. One of: dev, staging, prod. Default: dev.
# dev: local Docker development with DevTools; staging: Kubernetes testing; prod: production.
SPRING_PROFILES_ACTIVE=dev

# Optional. String. JVM options for production mode.
JAVA_OPTS=-Xms256m -Xmx512m -XX:+UseZGC

# Optional. String. Maven options for development mode (docker-compose.override.yml).
MAVEN_OPTS=-Xmx512m

# Optional. String. Docker Compose credential for the local PostgreSQL container.
POSTGRES_USER=demo
# Optional. String. Docker Compose credential for the local PostgreSQL container.
POSTGRES_PASSWORD=demo

# Required. String, min 32 chars. HS256 JWT signing key. Generate: openssl rand -hex 32
CRUD_BE_JAVA_SPRINGBOOT_JWT_SECRET=change-me-in-production-use-a-real-random-secret

# Optional. String. PostgreSQL URL for E2E tests (used by crud-be-e2e).
# Format: postgresql://<user>:<pass>@<host>:<port>/<dbname>
DATABASE_URL=postgresql://demo:demo@localhost:5432/crud_be
