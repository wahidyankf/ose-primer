# Demo Frontend (Dart/Flutter Web) Environment Variables
# Copy this file to .env and configure as needed

# Optional. String. Docker Compose credential for the local PostgreSQL container.
POSTGRES_USER=demo
# Optional. String. Docker Compose credential for the local PostgreSQL container.
POSTGRES_PASSWORD=demo

# Required (for Docker backend). String, min 32 chars. HS256 JWT signing key for the backend.
# Must match CRUD_BE_GOLANG_GIN_JWT_SECRET in the running backend container.
# Generate: openssl rand -hex 32
CRUD_BE_GOLANG_GIN_JWT_SECRET=change-me-in-dev-only-not-for-production
