{
  "name": "crud-contracts",
  "root": "specs/apps/crud/containers/contracts",
  "targets": {
    "lint": {
      "command": "mkdir -p specs/apps/crud/containers/contracts/generated && npx @redocly/cli bundle specs/apps/crud/containers/contracts/openapi.yaml -o specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml && npx @redocly/cli bundle specs/apps/crud/containers/contracts/openapi.yaml -o specs/apps/crud/containers/contracts/generated/openapi-bundled.json && npx @stoplight/spectral-cli lint specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml --ruleset specs/apps/crud/containers/contracts/.spectral.yaml",
      "cache": true,
      "inputs": ["{projectRoot}/**/*.yaml", "!{projectRoot}/generated/**", "!{projectRoot}/examples/**"]
    },
    "bundle": {
      "command": "mkdir -p specs/apps/crud/containers/contracts/generated && npx @redocly/cli bundle specs/apps/crud/containers/contracts/openapi.yaml -o specs/apps/crud/containers/contracts/generated/openapi-bundled.yaml && npx @redocly/cli bundle specs/apps/crud/containers/contracts/openapi.yaml -o specs/apps/crud/containers/contracts/generated/openapi-bundled.json",
      "cache": true,
      "inputs": ["{projectRoot}/**/*.yaml", "!{projectRoot}/generated/**", "!{projectRoot}/examples/**"],
      "outputs": ["{projectRoot}/generated/openapi-bundled.yaml", "{projectRoot}/generated/openapi-bundled.json"]
    },
    "docs": {
      "command": "mkdir -p specs/apps/crud/containers/contracts/generated/docs && npx @redocly/cli bundle specs/apps/crud/containers/contracts/openapi.yaml --config specs/apps/crud/containers/contracts/redocly.yaml --remove-unused-components -o specs/apps/crud/containers/contracts/generated/openapi-docs.yaml && npx @redocly/cli build-docs specs/apps/crud/containers/contracts/generated/openapi-docs.yaml -o specs/apps/crud/containers/contracts/generated/docs/index.html",
      "dependsOn": ["bundle"],
      "cache": true,
      "inputs": ["{projectRoot}/generated/openapi-bundled.yaml", "{projectRoot}/redocly.yaml"],
      "outputs": ["{projectRoot}/generated/docs/"]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'typecheck: no typecheck for this language (echo placeholder)'"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:unit: no unit tests (echo placeholder)'"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:coverage: no coverage tool configured (echo placeholder)'"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:integration: no integration tests (echo placeholder)'"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "specs:structure-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs structure validate"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/apps/rhino-cli/src/**/*.rs", "{workspaceRoot}/specs/apps/**/*"]
    },
    "specs:behavior:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'specs:behavior:coverage: no Gherkin behavior specs for this OpenAPI contract project (echo placeholder)'"
      }
    },
    "test:specs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-contracts:specs:structure-validation",
          "nx run crud-contracts:specs:behavior:coverage"
        ],
        "parallel": false
      },
      "cache": true
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run crud-contracts:typecheck",
          "nx run crud-contracts:lint",
          "nx run crud-contracts:test:unit",
          "nx run crud-contracts:test:coverage",
          "nx run crud-contracts:test:specs"
        ],
        "parallel": false
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'deps:audit: no package dependencies (OpenAPI spec container)'"
      }
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  }
}
