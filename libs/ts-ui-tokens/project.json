{
  "name": "ts-ui-tokens",
  "sourceRoot": "libs/ts-ui-tokens/src",
  "projectType": "library",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit",
        "cwd": "libs/ts-ui-tokens"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No lint configured for ts-ui-tokens (CSS + minimal TS)'"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:unit: no unit tests (echo placeholder)'"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:integration: no integration tests (echo placeholder)'"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx run ts-ui-tokens:typecheck", "nx run ts-ui-tokens:lint"],
        "parallel": false
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm audit --audit-level=moderate",
        "cwd": "libs/ts-ui-tokens"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "tags": ["type:lib", "lang:ts", "domain:ui"]
}
