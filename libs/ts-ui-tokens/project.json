{
  "name": "ts-ui-tokens",
  "sourceRoot": "libs/ts-ui-tokens/src",
  "projectType": "library",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit",
        "cwd": "libs/ts-ui-tokens"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'No lint configured for ts-ui-tokens (CSS + minimal TS)'"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx vitest run",
          "! grep -rnE '\\.(skip|todo)\\(' --include='*.test.*' --include='*.steps.*' src"
        ],
        "parallel": false,
        "cwd": "libs/ts-ui-tokens"
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:coverage: @vitest/coverage-v8 omitted deliberately — its addition destabilizes npm hoisting for unrelated crud-fe-ts-nextjs/crud-be-ts-effect/crud-fe-ts-tanstack-start/crud-fs-ts-nextjs vitest/rolldown resolution (verified via bisection); the 2 real vitest-cucumber scenarios already exercise 100% of this 4-file token-export lib (echo placeholder)'",
        "cwd": "libs/ts-ui-tokens"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:integration: no integration tests (echo placeholder)'"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "specs:structure-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs counts validate specs/libs/ts-ui-tokens"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/apps/rhino-cli/src/**/*.rs", "{workspaceRoot}/specs/libs/ts-ui-tokens/**/*"]
    },
    "specs:behavior:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs behavior-coverage validate specs/libs/ts-ui-tokens/behavior/gherkin libs/ts-ui-tokens"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/specs/libs/ts-ui-tokens/behavior/gherkin/**/*.feature", "{projectRoot}/src/**/*.ts"]
    },
    "test:specs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["nx run ts-ui-tokens:specs:structure-validation", "nx run ts-ui-tokens:specs:behavior:coverage"],
        "parallel": false
      },
      "cache": true
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run ts-ui-tokens:typecheck",
          "nx run ts-ui-tokens:lint",
          "nx run ts-ui-tokens:test:unit",
          "nx run ts-ui-tokens:test:coverage",
          "nx run ts-ui-tokens:test:specs"
        ],
        "parallel": false
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm audit --audit-level=moderate",
        "cwd": "libs/ts-ui-tokens"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "tags": ["type:lib", "lang:ts", "domain:ui"],
  "namedInputs": {
    "specs": ["{workspaceRoot}/specs/libs/ts-ui-tokens/behavior/gherkin/**/*.feature"]
  }
}
