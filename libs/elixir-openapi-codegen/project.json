{
  "name": "elixir-openapi-codegen",
  "sourceRoot": "libs/elixir-openapi-codegen/lib",
  "projectType": "library",
  "targets": {
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "mix cover.lcov",
          "(cd ../../ && cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- test-coverage validate libs/elixir-openapi-codegen/cover/lcov.info 90)",
          "mix credo --strict",
          "mix format --check-formatted"
        ],
        "parallel": false,
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix test",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix credo --strict",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix compile --warnings-as-errors",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix deps.get",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:integration: no integration tests (echo placeholder)'"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix hex.audit",
        "cwd": "libs/elixir-openapi-codegen"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "tags": ["type:lib", "lang:elixir", "domain:tooling"],
  "implicitDependencies": ["crud-contracts", "rhino-cli"]
}
