{
  "name": "elixir-openapi-codegen",
  "sourceRoot": "libs/elixir-openapi-codegen/lib",
  "projectType": "library",
  "targets": {
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "mix cover.lcov",
          "(cd ../../apps/rhino-cli && CGO_ENABLED=0 go run main.go test-coverage validate libs/elixir-openapi-codegen/cover/lcov.info 90)",
          "mix credo --strict",
          "mix format --check-formatted"
        ],
        "parallel": false,
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix test",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix credo --strict",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix compile --warnings-as-errors",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix deps.get",
        "cwd": "libs/elixir-openapi-codegen"
      }
    }
  },
  "tags": [
    "type:lib",
    "lang:elixir"
  ],
  "implicitDependencies": [
    "demo-contracts",
    "rhino-cli"
  ]
}
