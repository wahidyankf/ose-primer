{
  "name": "elixir-openapi-codegen",
  "sourceRoot": "libs/elixir-openapi-codegen/lib",
  "projectType": "library",
  "targets": {
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run elixir-openapi-codegen:typecheck",
          "nx run elixir-openapi-codegen:lint",
          "nx run elixir-openapi-codegen:test:unit",
          "nx run elixir-openapi-codegen:test:coverage",
          "nx run elixir-openapi-codegen:test:specs"
        ],
        "parallel": false
      }
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix cover.lcov",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix test",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix credo --strict",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix compile --warnings-as-errors",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "install": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix deps.get",
        "cwd": "libs/elixir-openapi-codegen"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:integration: no integration tests (echo placeholder)'"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "specs:structure-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs counts validate specs/libs/elixir-openapi-codegen"
      },
      "cache": true,
      "inputs": ["{workspaceRoot}/apps/rhino-cli/src/**/*.rs", "{workspaceRoot}/specs/libs/elixir-openapi-codegen/**/*"]
    },
    "specs:behavior:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'specs:behavior:coverage: no Gherkin behavior specs for this codegen library (echo placeholder)'"
      }
    },
    "test:specs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run elixir-openapi-codegen:specs:structure-validation",
          "nx run elixir-openapi-codegen:specs:behavior:coverage"
        ],
        "parallel": false
      },
      "cache": true
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mix hex.audit",
        "cwd": "libs/elixir-openapi-codegen"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "tags": ["type:lib", "lang:elixir", "domain:tooling"],
  "implicitDependencies": ["crud-contracts", "rhino-cli"]
}
