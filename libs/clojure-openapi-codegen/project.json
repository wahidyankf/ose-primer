{
  "name": "clojure-openapi-codegen",
  "sourceRoot": "libs/clojure-openapi-codegen",
  "projectType": "library",
  "tags": ["type:lib", "lang:clojure", "domain:tooling"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "command": "mkdir -p classes && JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -M -e '(compile (symbol \"openapi-codegen.core\"))'",
        "cwd": "libs/clojure-openapi-codegen"
      },
      "cache": true,
      "inputs": ["{projectRoot}/src/**/*.clj", "{projectRoot}/deps.edn"],
      "outputs": ["{projectRoot}/classes"]
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -M:test -m kaocha.runner unit bdd",
        "cwd": "libs/clojure-openapi-codegen"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.clj",
        "{projectRoot}/test/**/*.clj",
        "{projectRoot}/deps.edn",
        "{projectRoot}/tests.edn",
        "{workspaceRoot}/specs/libs/clojure-openapi-codegen/behavior/gherkin/**/*.feature"
      ]
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run clojure-openapi-codegen:typecheck",
          "nx run clojure-openapi-codegen:lint",
          "nx run clojure-openapi-codegen:test:unit",
          "nx run clojure-openapi-codegen:test:coverage",
          "nx run clojure-openapi-codegen:test:specs"
        ],
        "parallel": false
      },
      "cache": true
    },
    "test:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "libs/clojure-openapi-codegen",
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -M:coverage -m kaocha.runner unit bdd --plugin cloverage --lcov --cov-output coverage"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.clj",
        "{projectRoot}/test/**/*.clj",
        "{projectRoot}/deps.edn",
        "{projectRoot}/tests.edn",
        "{workspaceRoot}/specs/libs/clojure-openapi-codegen/behavior/gherkin/**/*.feature"
      ],
      "outputs": ["{projectRoot}/coverage"]
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "clj-kondo --lint src test",
        "cwd": "libs/clojure-openapi-codegen"
      },
      "cache": true
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:integration: no integration tests (echo placeholder)'"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'typecheck: no typecheck for this language (echo placeholder)'"
      }
    },
    "specs:structure-validation": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs counts validate specs/libs/clojure-openapi-codegen"
      },
      "cache": true,
      "inputs": [
        "{workspaceRoot}/apps/rhino-cli/src/**/*.rs",
        "{workspaceRoot}/specs/libs/clojure-openapi-codegen/**/*"
      ]
    },
    "specs:behavior:coverage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- specs behavior-coverage validate --shared-steps specs/libs/clojure-openapi-codegen/behavior/gherkin libs/clojure-openapi-codegen"
      },
      "cache": true,
      "inputs": [
        "{workspaceRoot}/specs/libs/clojure-openapi-codegen/behavior/gherkin/**/*.feature",
        "{projectRoot}/**/*.clj"
      ]
    },
    "test:specs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "nx run clojure-openapi-codegen:specs:structure-validation",
          "nx run clojure-openapi-codegen:specs:behavior:coverage"
        ],
        "parallel": false
      },
      "cache": true
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "JAVA_HOME=${JAVA_HOME_21_X64:-$JAVA_HOME} clojure -M:nvd check",
        "cwd": "libs/clojure-openapi-codegen"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "implicitDependencies": ["crud-contracts", "rhino-cli"],
  "namedInputs": {
    "specs": ["{workspaceRoot}/specs/libs/clojure-openapi-codegen/behavior/gherkin/**/*.feature"]
  }
}
