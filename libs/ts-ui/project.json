{
  "name": "ts-ui",
  "sourceRoot": "libs/ts-ui/src",
  "projectType": "library",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx tsc --noEmit",
        "cwd": "libs/ts-ui"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx oxlint@latest --jsx-a11y-plugin .",
        "cwd": "libs/ts-ui"
      }
    },
    "test:unit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --coverage",
        "cwd": "libs/ts-ui"
      }
    },
    "test:quick": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx vitest run --coverage && cd ../../ && cargo run --release --quiet --manifest-path apps/rhino-cli/Cargo.toml -- test-coverage validate libs/ts-ui/coverage/lcov.info 70",
        "cwd": "libs/ts-ui"
      }
    },
    "storybook": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx storybook dev -p 6006 --no-open",
        "cwd": "libs/ts-ui"
      }
    },
    "build-storybook": {
      "executor": "nx:run-commands",
      "cache": true,
      "options": {
        "command": "npx storybook build -o storybook-static",
        "cwd": "libs/ts-ui"
      },
      "outputs": ["{projectRoot}/storybook-static"]
    },
    "test:visual": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npx playwright test --config e2e/playwright.config.ts",
        "cwd": "libs/ts-ui"
      }
    },
    "test:integration": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:integration: no integration tests (echo placeholder)'"
      }
    },
    "test:e2e": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'test:e2e: not an e2e project (echo placeholder)'"
      }
    },
    "deps:audit": {
      "executor": "nx:run-commands",
      "options": {
        "command": "npm audit --audit-level=moderate",
        "cwd": "libs/ts-ui"
      },
      "cache": false
    },
    "compat:min-version": {
      "executor": "nx:run-commands",
      "options": {
        "command": "echo 'compat:min-version: no min-version check for this language'"
      }
    }
  },
  "tags": ["type:lib", "lang:ts", "domain:ui"]
}
