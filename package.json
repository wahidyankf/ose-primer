{
  "name": "ose-primer",
  "version": "1.0.0",
  "description": "Repository template for OSE-style polyglot Nx monorepos",
  "private": true,
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "build": "nx run-many -t build",
    "test": "nx run-many -t test:quick",
    "lint": "nx run-many -t lint",
    "lint:md": "markdownlint-cli2 \"**/*.md\"",
    "lint:md:fix": "markdownlint-cli2 --fix \"**/*.md\"",
    "format:md": "prettier --write \"**/*.md\"",
    "format:md:check": "prettier --check \"**/*.md\"",
    "affected:build": "nx affected -t build",
    "affected:test": "nx affected -t test:quick",
    "affected:lint": "nx affected -t lint",
    "graph": "nx graph",
    "nx": "nx",
    "prepare": "husky",
    "postinstall": "npm run doctor || true",
    "crud-be:dev": "cd infra/dev/crud-be-java-springboot && docker compose up",
    "crud-be:dev:restart": "cd infra/dev/crud-be-java-springboot && docker compose down && docker compose up",
    "crud-be:clean": "sudo chown -R $USER:$USER apps/crud-be-java-springboot/target && rm -rf apps/crud-be-java-springboot/target",
    "dev:crud-be-golang-gin": "docker compose -f infra/dev/crud-be-golang-gin/docker-compose.yml up --build",
    "dev:crud-be-java-springboot": "docker compose -f infra/dev/crud-be-java-springboot/docker-compose.yml up --build",
    "dev:crud-be-java-vertx": "docker compose -f infra/dev/crud-be-java-vertx/docker-compose.yml up --build",
    "dev:crud-be-elixir-phoenix": "docker compose -f infra/dev/crud-be-elixir-phoenix/docker-compose.yml up --build",
    "dev:crud-be-fsharp-giraffe": "docker compose -f infra/dev/crud-be-fsharp-giraffe/docker-compose.yml up --build",
    "dev:crud-be-csharp-aspnetcore": "docker compose -f infra/dev/crud-be-csharp-aspnetcore/docker-compose.yml up --build",
    "dev:crud-be-kotlin-ktor": "docker compose -f infra/dev/crud-be-kotlin-ktor/docker-compose.yml up --build",
    "dev:crud-be-python-fastapi": "docker compose -f infra/dev/crud-be-python-fastapi/docker-compose.yml up --build",
    "dev:crud-be-rust-axum": "docker compose -f infra/dev/crud-be-rust-axum/docker-compose.yml up --build",
    "dev:crud-be-ts-effect": "docker compose -f infra/dev/crud-be-ts-effect/docker-compose.yml up --build",
    "dev:crud-be-clojure-pedestal": "docker compose -f infra/dev/crud-be-clojure-pedestal/docker-compose.yml up --build",
    "dev:crud-fe-ts-nextjs": "docker compose -f infra/dev/crud-fe-ts-nextjs/docker-compose.yml up --build",
    "dev:crud-fe-ts-tanstack-start": "docker compose -f infra/dev/crud-fe-ts-tanstack-start/docker-compose.yml up --build",
    "dev:crud-fe-dart-flutterweb": "docker compose -f infra/dev/crud-fe-dart-flutterweb/docker-compose.yml up --build",
    "dev:crud-fs-ts-nextjs": "docker compose -f infra/dev/crud-fs-ts-nextjs/docker-compose.yml up --build",
    "generate:bindings": "cargo run --release --quiet --manifest-path apps/rhino-cli-rust/Cargo.toml -- agents sync && cargo run --release --quiet --manifest-path apps/rhino-cli-rust/Cargo.toml -- agents emit-bindings",
    "sync:agents": "cargo run --release --quiet --manifest-path apps/rhino-cli-rust/Cargo.toml -- agents sync --agents-only",
    "sync:skills": "cargo run --release --quiet --manifest-path apps/rhino-cli-rust/Cargo.toml -- agents sync --skills-only",
    "sync:dry-run": "cargo run --release --quiet --manifest-path apps/rhino-cli-rust/Cargo.toml -- agents sync --dry-run",
    "validate:sync": "cargo run --release --quiet --manifest-path apps/rhino-cli-rust/Cargo.toml -- agents validate-sync",
    "validate:harness-bindings": "cargo run --release --quiet --manifest-path apps/rhino-cli-rust/Cargo.toml -- agents validate-bindings",
    "validate:claude": "cargo run --release --quiet --manifest-path apps/rhino-cli-rust/Cargo.toml -- agents validate-claude",
    "validate:opencode": "npm run validate:sync",
    "validate:config": "npm run validate:claude && npm run generate:bindings && npm run validate:opencode",
    "doctor": "nx run rhino-cli-rust:build && ./apps/rhino-cli-rust/dist/rhino-cli doctor"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "commonjs",
  "volta": {
    "node": "24.16.0",
    "npm": "11.10.1"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@hey-api/client-fetch": "0.13.1",
    "@hey-api/openapi-ts": "0.94.5",
    "@openapitools/openapi-generator-cli": "2.31.0",
    "@redocly/cli": "2.25.1",
    "@stoplight/spectral-cli": "6.15.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "markdownlint-cli2": "0.22.0",
    "nx": "22.6.2",
    "prettier": "3.8.1",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tsx": "4.21.0"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs}": "prettier --write",
    "*.json": "prettier --write",
    "*.go": "gofmt -w",
    "*.fs": "fantomas",
    "*.{ex,exs}": "scripts/format-elixir.sh",
    "*.py": "ruff format",
    "*.rs": "rustfmt --edition 2024",
    "*.cs": "scripts/format-csharp.sh",
    "*.clj": "scripts/format-clojure.sh",
    "*.dart": "scripts/format-dart.sh",
    "*.md": "prettier --write",
    "*.{yml,yaml}": "prettier --write",
    "*.{css,scss}": "prettier --write"
  },
  "dependencies": {
    "tailwindcss": "4.2.2"
  }
}
